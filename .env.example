# NMS Final Competition secure environment template
# Run: python scripts/bootstrap_env.py to create a local .env with safe random keys.

SECRET_KEY=
MESSAGE_ENCRYPTION_KEY=
DATABASE_URL=sqlite:///naf_messaging.db

HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=1
APP_ENV=development

SESSION_TIMEOUT_MINUTES=30
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax
WTF_CSRF_ENABLED=1
WTF_CSRF_TIME_LIMIT=7200

RATELIMIT_DEFAULT=300 per hour
RATELIMIT_STORAGE_URI=memory://
MAX_CONTENT_LENGTH=26214400
SOCKETIO_CORS_ORIGINS=
